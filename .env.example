# ─── Contact form (Resend) ──────────────────────────────────────────────
# Get an API key at https://resend.com/api-keys
# Free tier: 3000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Destination inbox (where contact form submissions are sent)
CONTACT_TO=developmentteam@uncdevelopment.com

# Sender — MUST use a domain you've verified in Resend
# (or "onboarding@resend.dev" for testing only — Resend allows this
# without domain verification, but it sends from their domain.)
CONTACT_FROM="UNC Development <contact@uncdevelopment.com>"
