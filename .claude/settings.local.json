      "Bash(curl -s http://localhost:3001/)",
      "Bash(mkdir -p /tmp/portfolio-screens)",
      "Bash(\"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\" --headless --disable-gpu --no-sandbox --hide-scrollbars --window-size=1440,900 --screenshot=/tmp/portfolio-screens/hero.png http://localhost:3001/)",
      "Bash(\"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\" --headless --disable-gpu --no-sandbox --hide-scrollbars --window-size=1440,1100 --screenshot=/tmp/portfolio-screens/work.png http://localhost:3001/#work)",
      "Bash(\"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\" --headless --disable-gpu --no-sandbox --hide-scrollbars --window-size=1440,1100 --screenshot=/tmp/portfolio-screens/services.png http://localhost:3001/#services)"
    ]
  }
